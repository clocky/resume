---
import "../styles/style.scss";
import resume from "../_data/resume.json";
import { Icon } from "astro-icon/components";

const networkIcons: Record<string, string> = {
  X: "pixel:twitter",
  GitHub: "pixel:github",
  Bluesky: "pixel:bluesky",
  Instagram: "pixel:instagram",
  LinkedIn: "pixel:linkedin",
};

interface Props {
  title: string;
}

const { title } = Astro.props;
const isProd = import.meta.env.PROD;
const currentYear = new Date().getFullYear();
const location = (resume.basics.location ?? {}) as {
  city?: string;
  postalCode?: string;
  countryCode?: string;
  region?: string;
};
---

<!doctype html>
<html lang="en" itemscope itemtype="https://schema.org/Person">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content={resume.basics.name} />
    <meta name="description" content={resume.basics.summary} />
    {resume.meta?.canonical && <link rel="canonical" href={resume.meta.canonical} />}
    {resume.meta?.version && <meta name="version" content={resume.meta.version} />}
    {resume.meta?.lastModified && <meta name="last-modified" content={resume.meta.lastModified} />}
    <meta itemprop="email" content={resume.basics.email} />
    <meta itemprop="url" content={resume.basics.url} />
    <meta itemprop="jobTitle" content={resume.basics.label} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://static.cloudflareinsights.com" />
    <title>{title}</title>
    {
      isProd && (
        <>
          <link rel="preconnect" href="https://plausible.io" />
          <script
            is:inline
            defer
            data-domain="mark.mclaughlin.me.uk"
            src="https://plausible.io/js/plausible.js"
          />
          <meta
            name="google-site-verification"
            content="2SaJSS986anFYxGRY0-rz6ddYetFNTN5ILAU0zVvcaY"
          />
        </>
      )
    }
  </head>
  <body>
    <header>
      <h1 itemprop="name">{resume.basics.name}</h1>
      <p id="summary" itemprop="description">{resume.basics.summary.trim()}</p>
      {(location.city || location.postalCode || location.countryCode || location.region) && (
        <span itemprop="homeLocation" itemscope itemtype="https://schema.org/Place" hidden>
          <span itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
            {location.city && <meta itemprop="addressLocality" content={location.city} />}
            {location.postalCode && <meta itemprop="postalCode" content={location.postalCode} />}
            {location.countryCode && <meta itemprop="addressCountry" content={location.countryCode} />}
            {location.region && <meta itemprop="addressRegion" content={location.region} />}
          </span>
        </span>
      )}
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        © <time>{currentYear}</time>
        <span>{resume.basics.name}</span>
      </p>
      <ul>
        {
          resume.basics.profiles.map((profile) => (
            <li>
              <a href={profile.url} rel="me" itemprop="sameAs">
                <Icon name={networkIcons[profile.network] ?? `pixel:${profile.network.toLowerCase()}`} />
                <span class="sr-only">{profile.network}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </footer>
    <!-- Cloudflare Web Analytics -->
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "848d81a3a7004763960fa8158cf59596"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </body>
</html>
